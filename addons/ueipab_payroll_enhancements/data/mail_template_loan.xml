<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="email_template_loan_advance" model="mail.template">
        <field name="name">Adelanto de Salario – Notificación al Empleado</field>
        <field name="model_id" ref="ohrms_loan.model_hr_loan"/>
        <field name="email_from">"Recursos Humanos" &lt;recursoshumanos@ueipab.edu.ve&gt;</field>
        <field name="email_to">{{object.employee_id.work_email}}</field>
        <field name="email_cc">recursoshumanos@ueipab.edu.ve</field>
        <field name="subject">💰 ADELANTO DE SALARIO │ Nro.: {{object.name}} │ {{object.employee_id.name}}</field>

        <field name="body_html" type="html">
<div style="font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background-color:#f4f4f4;margin:0;padding:20px">
  <div style="max-width:680px;margin:0 auto;background-color:white;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,0.1);overflow:hidden">

    <!-- HEADER -->
    <div style="background:linear-gradient(135deg,#1a2c5b 0%,#2471a3 100%);color:white;padding:30px;text-align:center">
      <h1 style="margin:0;font-size:26px;font-weight:600">💰 Adelanto de Salario</h1>
      <p style="margin:6px 0 0;font-size:15px;opacity:0.9">Instituto Privado Andrés Bello, CA</p>
    </div>

    <div style="padding:30px">

      <p style="font-size:16px;color:#333;margin-bottom:20px">
        Estimado/a <strong t-out="object.employee_id.name"/>,
      </p>
      <p style="font-size:14px;color:#555;line-height:1.6;margin-bottom:24px">
        Le informamos que se ha procesado un <strong>adelanto de salario</strong> a su favor.
        A continuación encontrará el detalle del mismo.
      </p>

      <!-- INFO ROWS -->
      <div style="background:#f0f4fa;border-radius:8px;padding:20px;margin-bottom:24px">

        <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #d0dce8">
          <span style="font-weight:600;color:#1a2c5b;font-size:13px">📋 Nro. Adelanto:</span>
          <span style="color:#333;font-size:13px"><t t-out="object.name"/></span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #d0dce8">
          <span style="font-weight:600;color:#1a2c5b;font-size:13px">👤 Empleado:</span>
          <span style="color:#333;font-size:13px"><t t-out="object.employee_id.name"/></span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #d0dce8">
          <span style="font-weight:600;color:#1a2c5b;font-size:13px">🆔 Cédula:</span>
          <span style="color:#333;font-size:13px">
            <t t-out="object.employee_id.identification_id or 'N/A'"/>
          </span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:7px 0">
          <span style="font-weight:600;color:#1a2c5b;font-size:13px">📅 Fecha:</span>
          <span style="color:#333;font-size:13px">
            <t t-out="object.date" t-options='{"widget":"date","format":"dd/MM/yyyy"}'/>
          </span>
        </div>

      </div>

      <!-- AMOUNT BOX -->
      <t t-set="bs_total" t-value="object.advance_bs_amount or (object.loan_amount * (object.advance_exchange_rate or 1.0))"/>
      <div style="background:linear-gradient(135deg,#1a2c5b,#2471a3);border-radius:8px;padding:22px;margin-bottom:24px;text-align:center;color:white">
        <p style="margin:0 0 6px;font-size:13px;opacity:0.85;text-transform:uppercase;letter-spacing:.5px">Monto Adelantado</p>
        <p style="margin:0;font-size:32px;font-weight:700">
          Bs. <t t-out="'{:,.2f}'.format(bs_total)"/>
        </p>
      </div>

      <!-- REPAYMENT SCHEDULE -->
      <div style="background:#1a2c5b;color:white;padding:10px 16px;border-radius:6px 6px 0 0;font-size:14px;font-weight:600">
        📅 Plan de Recuperación
      </div>
      <table style="width:100%;border-collapse:collapse;margin-bottom:24px;font-size:13px">
        <thead>
          <tr style="background:#2471a3;color:white">
            <th style="padding:8px 12px;text-align:left">#</th>
            <th style="padding:8px 12px;text-align:left">Fecha de Descuento</th>
            <th style="padding:8px 12px;text-align:right">Monto</th>
          </tr>
        </thead>
        <tbody>
          <t t-foreach="object.loan_lines" t-as="line">
            <tr style="border-bottom:1px solid #e0e0e0">
              <td style="padding:8px 12px;color:#555">
                <t t-out="line_index + 1"/>
              </td>
              <td style="padding:8px 12px;color:#333">
                <t t-out="line.date" t-options='{"widget":"date","format":"dd/MM/yyyy"}'/>
              </td>
              <td style="padding:8px 12px;text-align:right;font-weight:600;color:#1a2c5b">
                Bs. <t t-out="'{:,.2f}'.format(line.amount * (object.advance_exchange_rate or 1.0))"/>
              </td>
            </tr>
          </t>
        </tbody>
      </table>

      <!-- LEGAL DECLARATION -->
      <div style="background:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:16px;margin-bottom:24px;font-size:12px;color:#555;line-height:1.7">
        <strong style="color:#1a2c5b">DECLARACIÓN DEL TRABAJADOR</strong><br/>
        El suscrito trabajador declara haber recibido de la
        <strong>UNIDAD EDUCATIVA INSTITUTO PRIVADO ANDRES BELLO, CA</strong>
        la cantidad de
        <strong>Bs. <t t-out="'{:,.2f}'.format(object.advance_bs_amount or (object.loan_amount * (object.advance_exchange_rate or 1.0)))"/></strong>
        por concepto de <strong>ADELANTO DE SALARIO</strong>, el cual será descontado
        de su nómina según el plan de recuperación indicado. Al confirmar la recepción
        digital, el trabajador acusa recibo del monto recibido y acepta las condiciones
        de recuperación establecidas.
      </div>

      <!-- INFO NOTE -->
      <div style="background:#e8f4f8;border-left:4px solid #2471a3;padding:14px 18px;margin-bottom:24px;border-radius:4px">
        <p style="font-size:13px;color:#1a2c5b;margin:0 0 6px"><strong>ℹ️ ¿Dudas o consultas?</strong></p>
        <p style="font-size:13px;color:#555;margin:0">
          Si tiene alguna duda por favor escribir a
          <a href="mailto:recursoshumanos@ueipab.edu.ve" style="color:#2471a3;text-decoration:none">recursoshumanos@ueipab.edu.ve</a>
        </p>
      </div>

    </div><!-- /padding -->

    <!-- ACK BUTTON -->
    <div style="background:linear-gradient(135deg,#28a745,#20c997);padding:28px 30px;text-align:center">
      <p style="margin:0 0 12px;color:white;font-size:15px;font-weight:600">
        ✅ Confirme la recepción digital de este adelanto
      </p>
      <p style="margin:0 0 18px;color:rgba(255,255,255,0.88);font-size:13px">
        Al hacer clic, acusa conformidad digital de que ha recibido el adelanto indicado.
      </p>
      <a t-att-href="object.loan_ack_url"
         style="display:inline-block;background:white;color:#28a745;padding:14px 40px;
                font-size:15px;font-weight:bold;text-decoration:none;border-radius:8px;
                box-shadow:0 4px 15px rgba(0,0,0,0.2)">
        Confirmar Recepción del Adelanto
      </a>
      <p style="margin:14px 0 0;color:rgba(255,255,255,0.75);font-size:12px">
        Su confirmación quedará registrada con fecha, hora e IP.
      </p>
    </div>

    <!-- FOOTER -->
    <div style="background:#f8f9fa;padding:18px 30px;text-align:center;font-size:12px;color:#888;border-top:1px solid #e0e0e0">
      <p style="margin:0">Instituto Privado Andrés Bello &#8226; <strong style="color:#1a2c5b">recursoshumanos@ueipab.edu.ve</strong></p>
      <p style="margin:6px 0 0;color:#aaa">Este es un documento generado automáticamente.</p>
    </div>

  </div>
</div>
        </field>
    </record>

</odoo>
