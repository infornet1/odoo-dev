<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend hr.loan form view to show recovery_type field -->
    <record id="hr_loan_view_form_ueipab" model="ir.ui.view">
        <field name="name">hr.loan.view.form.ueipab</field>
        <field name="model">hr.loan</field>
        <field name="inherit_id" ref="ohrms_loan.hr_loan_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='installment']" position="after">
                <field name="recovery_type" widget="radio"/>
            </xpath>
        </field>
    </record>

    <!-- Extend hr.loan tree view to show recovery_type column -->
    <record id="hr_loan_view_tree_ueipab" model="ir.ui.view">
        <field name="name">hr.loan.view.tree.ueipab</field>
        <field name="model">hr.loan</field>
        <field name="inherit_id" ref="ohrms_loan.hr_loan_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="recovery_type"/>
            </xpath>
        </field>
    </record>
</odoo>
