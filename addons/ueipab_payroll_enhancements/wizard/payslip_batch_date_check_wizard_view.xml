<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payslip_batch_date_check_wizard_form" model="ir.ui.view">
        <field name="name">hr.payslip.run.date.check.wizard.form</field>
        <field name="model">hr.payslip.run.date.check.wizard</field>
        <field name="arch" type="xml">
            <form string="Date Logic Check">
                <sheet>
                    <field name="run_id" invisible="1"/>
                    <field name="has_blocker" invisible="1"/>
                    <field name="sync_done" invisible="1"/>
                    <field name="seq_fix_date" invisible="1"/>

                    <div class="alert alert-success mb-2" invisible="not sync_done">
                        <i class="fa fa-check-circle me-1"/> Dates synchronized to all draft payslips.
                    </div>
                    <div class="alert alert-info mb-2" invisible="not seq_fix_date">
                        <i class="fa fa-info-circle me-1"/>
                        <strong>PAY1 Sequence Conflict:</strong>
                        The payroll journal sequence has already advanced beyond this batch's period.
                        Click <strong>"Auto-fix Accounting Dates"</strong> below to set the correct
                        accounting date on all draft payslips, then validate normally.
                        Alternatively, validating directly will apply the fix automatically.
                    </div>
                    <div class="alert alert-warning mb-2">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        <strong>Date logic issues detected.</strong>
                        Review before proceeding — or acknowledge to override.
                    </div>

                    <field name="issues_html" widget="html" readonly="1" nolabel="1"/>
                </sheet>
                <footer>
                    <button name="action_fix_accounting_dates"
                            type="object"
                            string="Auto-fix Accounting Dates"
                            class="btn-primary"
                            invisible="not seq_fix_date"/>
                    <button name="action_close"
                            type="object"
                            string="&#8592; Fix Dates"
                            class="btn-secondary"/>
                    <button name="action_acknowledge"
                            type="object"
                            string="Acknowledge &amp; Proceed"
                            class="btn-warning"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
