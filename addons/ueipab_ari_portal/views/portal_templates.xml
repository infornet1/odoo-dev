<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal: AR-I List -->
    <template id="portal_my_ari" name="Mis Declaraciones AR-I">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Declaraciones AR-I</t>
            </t>

            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Mis Declaraciones AR-I</h5>
                    <a href="/my/ari/new" class="btn btn-primary btn-sm">
                        <i class="fa fa-plus"/> Nueva Declaración
                    </a>
                </div>
            </div>

            <t t-if="not aris">
                <div class="alert alert-info">
                    <p class="mb-0">
                        No tiene declaraciones AR-I registradas.
                        <a href="/my/ari/new">Cree su primera declaración</a>.
                    </p>
                </div>
            </t>

            <t t-if="aris">
                <t t-set="state_labels" t-value="{'draft': 'Borrador', 'submitted': 'Enviado', 'approved': 'Aprobado', 'rejected': 'Rechazado', 'cancelled': 'Cancelado'}"/>
                <t t-set="period_labels" t-value="{'january': 'Enero (Inicial)', 'march': 'Marzo', 'june': 'Junio', 'september': 'Septiembre', 'december': 'Diciembre'}"/>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Referencia</th>
                            <th>Año</th>
                            <th>Período</th>
                            <th>Ingresos (Bs.)</th>
                            <th>% Retención</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="aris" t-as="ari">
                            <tr>
                                <td>
                                    <a t-attf-href="/my/ari/#{ari.id}">
                                        <t t-esc="ari.name"/>
                                    </a>
                                </td>
                                <td><t t-esc="ari.fiscal_year"/></td>
                                <td><t t-esc="period_labels.get(ari.variation_month, ari.variation_month)"/></td>
                                <td><t t-esc="'{:,.2f}'.format(ari.income_total)"/></td>
                                <td><t t-esc="'{:.2f}%'.format(ari.withholding_percentage)"/></td>
                                <td>
                                    <span t-attf-class="badge #{
                                        'bg-secondary' if ari.state == 'draft' else
                                        'bg-warning' if ari.state == 'submitted' else
                                        'bg-success' if ari.state == 'approved' else
                                        'bg-danger' if ari.state == 'rejected' else
                                        'bg-dark'
                                    }">
                                        <t t-esc="state_labels.get(ari.state, ari.state)"/>
                                    </span>
                                </td>
                                <td>
                                    <a t-attf-href="/my/ari/#{ari.id}/download"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Descargar Excel">
                                        <i class="fa fa-download"/>
                                    </a>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <t t-call="portal.pager"/>
            </t>
        </t>
    </template>

    <!-- Portal: AR-I Detail -->
    <template id="portal_my_ari_detail" name="Detalle Declaración AR-I">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" groups="hr.group_hr_manager">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/web#model=hr.employee.ari&amp;id=%d&amp;view_type=form' % ari.id"/>
                </t>
            </t>

            <t t-set="state_labels" t-value="{'draft': 'Borrador', 'submitted': 'Enviado', 'approved': 'Aprobado', 'rejected': 'Rechazado', 'cancelled': 'Cancelado'}"/>
            <t t-set="period_labels" t-value="{'january': 'Enero (Inicial)', 'march': 'Marzo', 'june': 'Junio', 'september': 'Septiembre', 'december': 'Diciembre'}"/>

            <div class="card mb-4">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <h4 class="mb-0">
                                Declaración AR-I: <t t-esc="ari.name"/>
                            </h4>
                        </div>
                        <div class="col-lg-4 text-lg-end">
                            <span t-attf-class="badge fs-6 #{
                                'bg-secondary' if ari.state == 'draft' else
                                'bg-warning' if ari.state == 'submitted' else
                                'bg-success' if ari.state == 'approved' else
                                'bg-danger' if ari.state == 'rejected' else
                                'bg-dark'
                            }">
                                <t t-esc="state_labels.get(ari.state, ari.state)"/>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Mensajes de alerta -->
                    <t t-if="request.params.get('message') == 'created'">
                        <div class="alert alert-success">
                            Declaración AR-I creada exitosamente. Revise los datos y envíe para aprobación de RRHH.
                        </div>
                    </t>
                    <t t-if="request.params.get('message') == 'submitted'">
                        <div class="alert alert-success">
                            Declaración AR-I enviada para revisión de RRHH.
                        </div>
                    </t>
                    <t t-if="ari.state == 'rejected'">
                        <div class="alert alert-danger">
                            <strong>Rechazada:</strong> <t t-esc="ari.rejection_reason"/>
                        </div>
                    </t>

                    <!-- Resumen -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6>Información de la Declaración</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td class="text-muted">Año Gravable:</td>
                                    <td><t t-esc="ari.fiscal_year"/></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Período:</td>
                                    <td><t t-esc="period_labels.get(ari.variation_month, ari.variation_month)"/></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Fecha de Entrega:</td>
                                    <td><t t-esc="ari.submission_date" t-options='{"widget": "date"}'/></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6>Resultados</h6>
                            <table class="table table-sm">
                                <tr>
                                    <td class="text-muted">Ingreso Total:</td>
                                    <td>Bs. <t t-esc="'{:,.2f}'.format(ari.income_total)"/></td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Ingreso en UT:</td>
                                    <td><t t-esc="'{:,.2f}'.format(ari.income_in_ut)"/> UT</td>
                                </tr>
                                <tr class="table-primary">
                                    <td class="text-muted"><strong>% Retención:</strong></td>
                                    <td><strong><t t-esc="'{:.2f}%'.format(ari.withholding_percentage)"/></strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Desglose detallado -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0">Ingresos (Sección A/B)</h6>
                                </div>
                                <div class="card-body">
                                    <table class="table table-sm mb-0">
                                        <tr>
                                            <td>Empleador Principal:</td>
                                            <td class="text-end">Bs. <t t-esc="'{:,.2f}'.format(ari.income_employer_primary)"/></td>
                                        </tr>
                                        <t t-if="ari.income_employer_b">
                                            <tr>
                                                <td><t t-esc="ari.employer_b_name or 'Empleador B'"/>:</td>
                                                <td class="text-end">Bs. <t t-esc="'{:,.2f}'.format(ari.income_employer_b)"/></td>
                                            </tr>
                                        </t>
                                        <tr class="table-secondary">
                                            <td><strong>Total:</strong></td>
                                            <td class="text-end"><strong>Bs. <t t-esc="'{:,.2f}'.format(ari.income_total)"/></strong></td>
                                        </tr>
                                        <tr>
                                            <td>Valor UT:</td>
                                            <td class="text-end">Bs. <t t-esc="'{:,.2f}'.format(ari.ut_value)"/></td>
                                        </tr>
                                        <tr>
                                            <td>Ingreso en UT:</td>
                                            <td class="text-end"><t t-esc="'{:,.2f}'.format(ari.income_in_ut)"/> UT</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0">Deducciones y Rebajas</h6>
                                </div>
                                <div class="card-body">
                                    <table class="table table-sm mb-0">
                                        <tr>
                                            <td>Tipo de Desgravamen:</td>
                                            <td class="text-end">
                                                <t t-if="ari.deduction_type == 'unique'">
                                                    Único (774 UT)
                                                </t>
                                                <t t-else="">
                                                    Detallado (<t t-esc="'{:,.2f}'.format(ari.deductions_in_ut)"/> UT)
                                                </t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Rebaja Personal:</td>
                                            <td class="text-end">10 UT</td>
                                        </tr>
                                        <tr>
                                            <td>Cargas Familiares:</td>
                                            <td class="text-end"><t t-esc="ari.cargas_familiares_count"/> × 10 = <t t-esc="ari.cargas_familiares_count * 10"/> UT</td>
                                        </tr>
                                        <tr class="table-secondary">
                                            <td><strong>Total Rebajas:</strong></td>
                                            <td class="text-end"><strong><t t-esc="'{:,.2f}'.format(ari.rebajas_total_ut)"/> UT</strong></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cálculo del impuesto -->
                    <div class="card mt-3">
                        <div class="card-header">
                            <h6 class="mb-0">Cálculo del Impuesto (Secciones F–J)</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Ingreso Gravable (F)</div>
                                        <div class="fs-5"><t t-esc="'{:,.2f}'.format(ari.taxable_income_ut)"/> UT</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Impuesto Estimado (G)</div>
                                        <div class="fs-5"><t t-esc="'{:,.2f}'.format(ari.estimated_tax_ut)"/> UT</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Impuesto a Retener (I)</div>
                                        <div class="fs-5"><t t-esc="'{:,.2f}'.format(ari.tax_to_withhold_ut)"/> UT</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center bg-primary text-white p-2 rounded">
                                        <div class="small">% Retención (J)</div>
                                        <div class="fs-3"><t t-esc="'{:.2f}%'.format(ari.withholding_percentage)"/></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Acciones -->
                    <div class="mt-4 d-flex gap-2">
                        <t t-if="ari.state == 'draft'">
                            <form t-attf-action="/my/ari/#{ari.id}/submit" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-send"/> Enviar para Revisión
                                </button>
                            </form>
                        </t>
                        <a t-attf-href="/my/ari/#{ari.id}/download" class="btn btn-outline-primary">
                            <i class="fa fa-download"/> Descargar Excel AR-I
                        </a>
                        <a href="/my/ari" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left"/> Volver al Listado
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal: AR-I Form (Crear) -->
    <template id="portal_ari_form" name="Nueva Declaración AR-I">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">Nueva Declaración AR-I</h4>
                </div>
                <div class="card-body">
                    <!-- Mensajes de error -->
                    <t t-if="error_message">
                        <div class="alert alert-danger">
                            <t t-foreach="error_message" t-as="msg">
                                <p class="mb-0"><t t-esc="msg"/></p>
                            </t>
                        </div>
                    </t>

                    <form action="/my/ari/create" method="post" class="o_portal_details_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <!-- Datos del empleado (solo lectura) -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <div class="alert alert-info">
                                    <strong>Empleado:</strong> <t t-esc="employee.name"/>
                                    <t t-if="employee.identification_id">
                                        | <strong>Cédula:</strong> <t t-esc="employee.identification_id"/>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Período de declaración -->
                        <h5>Período de Declaración</h5>
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label">Año Gravable *</label>
                                <select name="fiscal_year" class="form-select" required="required">
                                    <t t-foreach="available_years" t-as="yr">
                                        <option t-att-value="yr"
                                                t-att-selected="'selected' if yr == current_year else None">
                                            <t t-esc="yr"/>
                                        </option>
                                    </t>
                                </select>
                                <small class="text-muted">
                                    Seleccione el año gravable de la declaración (máximo el año en curso).
                                </small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Período *</label>
                                <select name="variation_month" class="form-select" required="required">
                                    <option value="january">Enero (Inicial)</option>
                                    <option value="march">Marzo</option>
                                    <option value="june">Junio</option>
                                    <option value="september">Septiembre</option>
                                    <option value="december">Diciembre</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">¿Es Variación?</label>
                                <div class="form-check mt-2">
                                    <input type="checkbox" name="is_variation" class="form-check-input"/>
                                    <label class="form-check-label">Esta es una declaración de variación</label>
                                </div>
                            </div>
                        </div>

                        <!-- Sección A: Ingresos -->
                        <h5>Sección A: Estimación de Ingresos Anuales (Bs.)</h5>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Ingresos de UEIPAB *</label>
                                <input type="number" name="income_employer_primary" class="form-control"
                                       step="0.01" required="required"
                                       t-att-value="'{:.2f}'.format(estimated_income or 0)"/>
                                <small class="text-muted">
                                    Estimado del contrato: Bs. <t t-esc="'{:,.2f}'.format(estimated_income or 0)"/>
                                </small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Valor de la UT (Bs.)</label>
                                <input type="number" name="ut_value" class="form-control"
                                       step="0.01" value="9.00"/>
                                <small class="text-muted">
                                    La UT vigente es <strong>Bs. 9,00</strong> según el SENIAT.
                                    Verifique en <strong>seniat.gob.ve</strong> si hubo actualización
                                    para el año gravable seleccionado.
                                </small>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Nombre del Segundo Empleador</label>
                                <input type="text" name="employer_b_name" class="form-control"
                                       placeholder="Dejar vacío si no aplica"/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ingresos del Empleador B</label>
                                <input type="number" name="income_employer_b" class="form-control"
                                       step="0.01" value="0"/>
                            </div>
                        </div>

                        <!-- Sección C/E: Deducciones -->
                        <h5>Deducciones</h5>
                        <div class="row mb-4">
                            <div class="col-12">
                                <div class="form-check">
                                    <input type="radio" name="deduction_type" value="unique"
                                           class="form-check-input" id="ded_unique" checked="checked"/>
                                    <label class="form-check-label" for="ded_unique">
                                        <strong>Desgravamen Único (774 UT)</strong>
                                        — No requiere comprobantes
                                    </label>
                                </div>
                                <div class="form-check mt-2">
                                    <input type="radio" name="deduction_type" value="itemized"
                                           class="form-check-input" id="ded_itemized"/>
                                    <label class="form-check-label" for="ded_itemized">
                                        <strong>Desgravámenes Detallados</strong>
                                        — Requiere comprobantes de respaldo
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Desgravámenes detallados (ocultos por defecto) -->
                        <div id="itemized_deductions" class="mb-4" style="display: none;">
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">1. Gastos de Educación (Bs.)</label>
                                    <input type="number" name="deduction_education" class="form-control"
                                           step="0.01" value="0"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">2. Primas de Seguros (Bs.)</label>
                                    <input type="number" name="deduction_insurance" class="form-control"
                                           step="0.01" value="0"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-md-6">
                                    <label class="form-label">3. Gastos Médicos y Odontológicos (Bs.)</label>
                                    <input type="number" name="deduction_medical" class="form-control"
                                           step="0.01" value="0"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">4. Gastos de Vivienda (Bs.)</label>
                                    <input type="number" name="deduction_housing" class="form-control"
                                           step="0.01" value="0"/>
                                    <select name="deduction_housing_type" class="form-select mt-1">
                                        <option value="">Seleccione tipo...</option>
                                        <option value="mortgage">Hipoteca (máx. 1.000 UT)</option>
                                        <option value="rent">Alquiler (máx. 800 UT)</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Sección H: Cargas Familiares -->
                        <h5>Sección H: Cargas Familiares</h5>
                        <p class="text-muted">Cada carga familiar otorga una rebaja de 10 UT</p>
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input type="checkbox" name="rebaja_spouse" class="form-check-input"/>
                                    <label class="form-check-label">Cónyuge</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Hijos menores de 25 años</label>
                                <input type="number" name="rebaja_children_under_25" class="form-control"
                                       min="0" value="0"/>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Hijos con discapacidad</label>
                                <input type="number" name="rebaja_children_disabled" class="form-control"
                                       min="0" value="0"/>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Padres dependientes</label>
                                <input type="number" name="rebaja_parents" class="form-control"
                                       min="0" value="0"/>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Exceso de Retención Años Anteriores (Bs.)</label>
                                <input type="number" name="rebaja_prior_excess" class="form-control"
                                       step="0.01" value="0"/>
                                <small class="text-muted">Si le retuvieron ISLR en exceso el año anterior</small>
                            </div>
                        </div>

                        <!-- Enviar -->
                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save"/> Crear Declaración
                                </button>
                                <a href="/my/ari" class="btn btn-outline-secondary ms-2">
                                    Cancelar
                                </a>
                            </div>
                        </div>
                    </form>

                    <script>
                        document.querySelectorAll('input[name="deduction_type"]').forEach(function(radio) {
                            radio.addEventListener('change', function() {
                                var itemizedDiv = document.getElementById('itemized_deductions');
                                itemizedDiv.style.display = (this.value === 'itemized') ? 'block' : 'none';
                            });
                        });
                    </script>
                </div>
            </div>
        </t>
    </template>

</odoo>
