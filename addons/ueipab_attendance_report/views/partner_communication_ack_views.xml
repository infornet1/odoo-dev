<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_partner_communication_ack" model="ir.actions.act_window">
        <field name="name">Comunicados a Representantes</field>
        <field name="res_model">partner.communication.ack</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record id="view_partner_communication_ack_tree" model="ir.ui.view">
        <field name="name">partner.communication.ack.tree</field>
        <field name="model">partner.communication.ack</field>
        <field name="arch" type="xml">
            <tree string="Comunicados a Representantes"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'continuing'"
                  decoration-info="state == 'leaving'">
                <field name="notice_label" optional="show"/>
                <field name="notice_key"   optional="hide"/>
                <field name="partner_name"/>
                <field name="partner_email"/>
                <field name="partner_phone" optional="hide"/>
                <field name="sent_date"     optional="show"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'continuing'"
                       decoration-info="state == 'leaving'"/>
                <field name="vote_channel" widget="badge"
                       decoration-info="vote_channel == 'email_link'"
                       decoration-success="vote_channel == 'whatsapp'"
                       decoration-warning="vote_channel in ('phone','in_person')"
                       optional="show"/>
                <field name="recorded_by"  optional="show"/>
                <field name="ack_date"     optional="show"/>
                <field name="days_pending" optional="show"/>
                <field name="bounce_wa_sent" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_partner_communication_ack_form" model="ir.ui.view">
        <field name="name">partner.communication.ack.form</field>
        <field name="model">partner.communication.ack</field>
        <field name="arch" type="xml">
            <form string="Comunicado a Representante">
                <header>
                    <button name="action_open_vote_wizard"
                            string="📞 Registrar voto asistido"
                            type="object" class="btn-primary"
                            invisible="state != 'pending'"/>
                    <button name="action_reset_pending" string="Reiniciar a Pendiente"
                            type="object"
                            invisible="state == 'pending'"
                            confirm="¿Está seguro de que desea reiniciar este voto? Esta acción elimina el registro de decisión del representante y no se puede deshacer."/>
                    <field name="state" widget="badge"
                           decoration-warning="state == 'pending'"
                           decoration-success="state == 'continuing'"
                           decoration-info="state == 'leaving'"
                           readonly="1"/>
                </header>
                <sheet>
                    <!-- Fix #3: outcome banners -->
                    <div class="alert alert-info mb-3"
                         invisible="state != 'leaving'">
                        <strong>ℹ️ Decisión registrada: Opción B.</strong>
                        Requiere seguimiento.
                    </div>
                    <div class="alert alert-success mb-3"
                         invisible="state != 'continuing'">
                        <strong>✅ Decisión registrada: Opción A.</strong>
                    </div>
                    <div class="alert alert-warning mb-3"
                         invisible="state != 'pending'">
                        <strong>⏳ Pendiente de respuesta.</strong>
                        El representante aún no ha votado.
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <!-- Fix #10: smart button to partner form -->
                        <button name="action_open_partner"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user"
                                string="Ver Contacto"
                                invisible="not partner_id"/>
                        <button name="action_open_vote_form_url"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-external-link"
                                string="Abrir formulario de voto (tablet)"
                                title="Abre el formulario público para voto presencial"
                                invisible="state != 'pending'"/>
                    </div>
                    <group>
                        <group string="Campaña">
                            <field name="notice_key"/>
                            <field name="notice_label"/>
                        </group>
                        <group string="Representante">
                            <field name="partner_id"/>
                            <field name="partner_name"/>
                            <field name="partner_email"/>
                            <field name="partner_phone"/>
                        </group>
                    </group>
                    <group>
                        <group string="Votación">
                            <field name="sent_date"/>
                            <field name="ack_date"/>
                            <!-- Fix #9: response time display -->
                            <field name="response_time"
                                   invisible="not response_time"/>
                            <field name="vote_channel" widget="badge"
                                   decoration-info="vote_channel == 'email_link'"
                                   decoration-success="vote_channel == 'whatsapp'"
                                   decoration-warning="vote_channel in ('phone','in_person')"/>
                            <field name="recorded_by"/>
                            <field name="days_pending"
                                   invisible="state != 'pending'"/>
                        </group>
                        <group string="Sistema">
                            <field name="token" groups="base.group_system"/>
                            <field name="bounce_wa_sent"/>
                            <field name="ack_ip"/>
                            <field name="freescout_conv_id"
                                   invisible="not freescout_conv_id"/>
                        </group>
                    </group>
                    <group string="Notas de auditoría">
                        <field name="vote_notes" nolabel="1"
                               readonly="state in ('continuing', 'leaving')"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_partner_communication_ack_search" model="ir.ui.view">
        <field name="name">partner.communication.ack.search</field>
        <field name="model">partner.communication.ack</field>
        <field name="arch" type="xml">
            <search string="Buscar comunicados">
                <field name="partner_name"/>
                <field name="partner_email"/>
                <field name="notice_key"/>
                <filter string="Pendientes"      name="pending"
                        domain="[('state','=','pending')]"/>
                <filter string="Opción A"        name="continuing"
                        domain="[('state','=','continuing')]"/>
                <filter string="Opción B"        name="leaving"
                        domain="[('state','=','leaving')]"/>
                <separator/>
                <filter string="Enlace de correo" name="ch_email"
                        domain="[('vote_channel','=','email_link')]"/>
                <filter string="WhatsApp"         name="ch_whatsapp"
                        domain="[('vote_channel','=','whatsapp')]"/>
                <filter string="Teléfono/Presencial" name="ch_staff"
                        domain="[('vote_channel','in',['phone','in_person'])]"/>
                <filter string="WA de rebote enviado" name="bounce_sent"
                        domain="[('bounce_wa_sent','=',True)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Campaña"  name="group_notice"
                            context="{'group_by':'notice_key'}"/>
                    <filter string="Decisión" name="group_state"
                            context="{'group_by':'state'}"/>
                    <filter string="Canal"    name="group_channel"
                            context="{'group_by':'vote_channel'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
