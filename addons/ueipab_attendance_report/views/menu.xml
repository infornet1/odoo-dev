<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard entry under Payroll → Reports (injected without touching ueipab_payroll_enhancements) -->
    <menuitem
        id="menu_attendance_report_wizard"
        name="Reporte de Asistencia Quincenal"
        parent="ueipab_payroll_enhancements.menu_payroll_reports"
        action="action_hr_attendance_report_wizard"
        sequence="90"
        groups="hr_payroll_community.group_hr_payroll_community_user"/>

    <!-- List view of all generated reports (same parent, sequence after wizard) -->
    <menuitem
        id="menu_attendance_report_list"
        name="Reportes Generados (Asistencia)"
        parent="ueipab_payroll_enhancements.menu_payroll_reports"
        action="action_hr_attendance_report"
        sequence="91"
        groups="hr_payroll_community.group_hr_payroll_community_user"/>

    <!-- Correction requests queue -->
    <menuitem
        id="menu_attendance_correction_list"
        name="Solicitudes de Corrección"
        parent="ueipab_payroll_enhancements.menu_payroll_reports"
        action="action_hr_attendance_correction"
        sequence="92"
        groups="hr_payroll_community.group_hr_payroll_community_user"/>

    <!-- Notice Acknowledgments tracking -->
    <menuitem
        id="menu_notice_acknowledgment_list"
        name="Notice Acknowledgments"
        parent="ueipab_payroll_enhancements.menu_payroll_reports"
        action="action_hr_notice_acknowledgment"
        sequence="95"
        groups="hr_payroll_community.group_hr_payroll_community_user"/>

    <!-- Partner Communication Ack (PDVSA continuacion, etc.) -->
    <menuitem
        id="menu_partner_communication_ack_list"
        name="Comunicados a Representantes"
        parent="ueipab_payroll_enhancements.menu_payroll_reports"
        action="action_partner_communication_ack"
        sequence="96"
        groups="hr_payroll_community.group_hr_payroll_community_user"/>

</odoo>
