<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_attendance_report_wizard_form" model="ir.ui.view">
        <field name="name">hr.attendance.report.wizard.form</field>
        <field name="model">hr.attendance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Reportes de Asistencia Quincenal">

                <!-- ===== MODE SELECTOR ===== -->
                <group string="Modo de generaci&#243;n" col="1">
                    <field name="generation_mode" widget="radio" nolabel="1"/>
                </group>

                <!-- ===== SINGLE QUINCENA (visible when mode = single) ===== -->
                <group string="Per&#237;odo" invisible="generation_mode == 'range'">
                    <group>
                        <field name="year"     required="generation_mode == 'single'"/>
                        <field name="month"    required="generation_mode == 'single'"/>
                        <field name="quincena" required="generation_mode == 'single'"/>
                    </group>
                    <group>
                        <field name="date_from" readonly="1" string="Fecha Inicio"/>
                        <field name="date_to"   readonly="1" string="Fecha Fin"/>
                    </group>
                </group>

                <!-- ===== RANGE / BULK (visible when mode = range) ===== -->
                <group string="Rango de meses" invisible="generation_mode == 'single'">
                    <group string="Desde">
                        <field name="range_from_month" required="generation_mode == 'range'"/>
                        <field name="range_from_year"  required="generation_mode == 'range'"/>
                    </group>
                    <group string="Hasta">
                        <field name="range_to_month" required="generation_mode == 'range'"/>
                        <field name="range_to_year"  required="generation_mode == 'range'"/>
                    </group>
                </group>

                <!-- Range preview info line -->
                <div invisible="generation_mode == 'single'"
                     style="background:#e8f4f8;border-left:4px solid #2471a3;padding:10px 14px;margin:0 0 8px;border-radius:4px;">
                    <span style="font-size:13px;color:#1a2c5b;">
                        &#128197;&#160;
                        <field name="range_preview" readonly="1" nolabel="1"
                               style="display:inline;font-weight:600;color:#1a2c5b;"/>
                    </span>
                </div>

                <!-- ===== EMPLOYEE SELECTION ===== -->
                <group string="Empleados a incluir" col="1">
                    <field name="filter_mode" widget="radio" nolabel="1"/>

                    <field name="department_id"
                           invisible="filter_mode != 'department'"
                           required="filter_mode == 'department'"
                           placeholder="Seleccione un departamento..."/>

                    <field name="employee_ids"
                           nolabel="1"
                           widget="many2many_tags"
                           invisible="filter_mode == 'all'"
                           readonly="filter_mode == 'department'"
                           domain="[('active','=',True)]"
                           options="{'no_create': True}"
                           placeholder="Escriba un nombre para buscar empleados..."/>
                </group>

                <!-- Live employee counter -->
                <div style="background:#e8f4f8;border-left:4px solid #2471a3;padding:10px 14px;margin:4px 0 12px;border-radius:4px;">
                    <span style="font-size:13px;color:#1a2c5b;">
                        &#128101;&#160;
                        <field name="employees_info" readonly="1" nolabel="1"
                               style="display:inline;font-weight:600;color:#1a2c5b;"/>
                    </span>
                </div>

                <!-- ===== SEND / RESEND OPTIONS ===== -->
                <group>
                    <field name="send_email" invisible="resend_only"/>
                    <field name="resend_only"/>
                </group>

                <!-- Resend info banner -->
                <div invisible="not resend_only"
                     style="background:#fff3cd;border-left:4px solid #ffc107;padding:10px 14px;margin:4px 0 12px;border-radius:4px;">
                    <span style="font-size:13px;color:#856404;">
                        &#128231;&#160;
                        <strong>Modo reenv&#237;o:</strong>
                        Solo se enviar&#225;n correos a empleados que ya tienen reporte para el per&#237;odo seleccionado. No se crear&#225;n nuevos registros.
                    </span>
                </div>

                <footer>
                    <button string="Generar Reportes"
                            name="action_generate_reports"
                            type="object"
                            class="btn-primary"
                            invisible="resend_only"/>
                    <button string="&#128231;  Reenviar Reportes"
                            name="action_resend_reports"
                            type="object"
                            class="btn-primary"
                            invisible="not resend_only"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard as dialog -->
    <record id="action_hr_attendance_report_wizard" model="ir.actions.act_window">
        <field name="name">Reporte de Asistencia Quincenal</field>
        <field name="res_model">hr.attendance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_hr_attendance_report_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
