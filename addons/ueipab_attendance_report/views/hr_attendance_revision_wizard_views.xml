<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_attendance_revision_wizard_form" model="ir.ui.view">
        <field name="name">hr.attendance.revision.wizard.form</field>
        <field name="model">hr.attendance.revision.wizard</field>
        <field name="arch" type="xml">
            <form string="Poner en Revisión">
                <sheet>
                    <field name="correction_id" invisible="1"/>
                    <div style="margin-bottom:6px;">
                        <label for="note" string="Nota para el empleado"
                               style="font-weight:700;font-size:13px;color:#333;"/>
                        <span style="font-size:12px;color:#888;margin-left:6px;">(opcional)</span>
                    </div>
                    <field name="note"
                           nolabel="1"
                           placeholder="Ej: Revisamos las cámaras del 26/05 y no se observa acceso al kiosco en ese horario. ¿Puedes aportar más información?"
                           style="width:100%;min-height:120px;resize:vertical;"/>
                    <p style="font-size:12px;color:#888;margin:4px 0 16px;">
                        Si lo dejas vacío se enviará solo la notificación estándar de revisión.
                    </p>
                    <group string="Documento adjunto (opcional)">
                        <field name="attachment" widget="binary" nolabel="1"/>
                        <field name="attachment_name" invisible="not attachment"
                               placeholder="nombre_archivo.pdf"/>
                    </group>
                </sheet>
                <footer>
                    <button string="🔍  Poner en Revisión"
                            name="action_confirm" type="object"
                            class="btn-warning"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
