<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_attendance_rejection_wizard_form" model="ir.ui.view">
        <field name="name">hr.attendance.rejection.wizard.form</field>
        <field name="model">hr.attendance.rejection.wizard</field>
        <field name="arch" type="xml">
            <form string="Rechazar solicitud">
                <sheet>
                    <field name="correction_id" invisible="1"/>
                    <div style="margin-bottom:6px;">
                        <label for="rejection_reason" string="Motivo de rechazo"
                               style="font-weight:700;font-size:13px;color:#333;"/>
                        <span style="font-size:12px;color:#888;margin-left:6px;">(opcional)</span>
                    </div>
                    <field name="rejection_reason"
                           nolabel="1"
                           placeholder="Ej: No se pudo verificar la presencia en el horario indicado. Por favor comuníquese con RRHH."
                           style="width:100%;min-height:100px;resize:vertical;"/>
                    <p style="font-size:12px;color:#888;margin:4px 0 0;">
                        Si lo dejas vacío, el correo al empleado no incluirá observación de RRHH.
                    </p>
                </sheet>
                <footer>
                    <button string="❌  Confirmar rechazo"
                            name="action_confirm" type="object"
                            class="btn-danger"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
