<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_enrollment_journey_tree" model="ir.ui.view">
        <field name="name">enrollment.journey.tree</field>
        <field name="model">enrollment.journey</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id"/>
                <field name="order_id"/>
                <field name="academic_year"/>
                <field name="progress_pct" widget="progressbar"/>
                <field name="current_step"/>
                <field name="step1_state"/>
                <field name="step2_state"/>
                <field name="step3_state"/>
                <field name="step4_state"/>
                <field name="step5_state"/>
                <field name="step6_state"/>
            </tree>
        </field>
    </record>

    <record id="view_enrollment_journey_form" model="ir.ui.view">
        <field name="name">enrollment.journey.form</field>
        <field name="model">enrollment.journey</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run_soft_checks" type="object"
                            string="🔄 Validaciones automáticas" class="btn-secondary"/>
                    <button name="action_open_journey_page" type="object"
                            string="🌐 Ver página del Representante" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="partner_id" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="order_id"/>
                            <field name="academic_year"/>
                            <field name="progress_pct" widget="progressbar"/>
                        </group>
                        <group>
                            <field name="journey_url" widget="url" readonly="1"/>
                            <field name="access_token" readonly="1" groups="base.group_system"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pasos">
                            <group string="1. Cotización confirmada">
                                <field name="step1_state"/>
                                <field name="step1_cleared_by"/>
                                <field name="step1_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 1}" class="btn-success"
                                        invisible="step1_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 1}"
                                        invisible="step1_state not in ('done_auto','done_manual')"/>
                            </group>
                            <group string="2. Acuerdo de Inscripción firmado">
                                <field name="step2_state"/>
                                <field name="step2_cleared_by"/>
                                <field name="step2_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 2}" class="btn-success"
                                        invisible="step2_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 2}"
                                        invisible="step2_state not in ('done_auto','done_manual')"/>
                            </group>
                            <group string="3. Registro Akdemia completo">
                                <field name="step3_state"/>
                                <field name="step3_cleared_by"/>
                                <field name="step3_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 3}" class="btn-success"
                                        invisible="step3_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 3}"
                                        invisible="step3_state not in ('done_auto','done_manual')"/>
                            </group>
                            <group string="4. Cuenta de correo @ueipab.edu.ve">
                                <field name="step4_state"/>
                                <field name="step4_cleared_by"/>
                                <field name="step4_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 4}" class="btn-success"
                                        invisible="step4_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 4}"
                                        invisible="step4_state not in ('done_auto','done_manual')"/>
                            </group>
                            <group string="5. Google Classroom">
                                <field name="step5_state"/>
                                <field name="step5_cleared_by"/>
                                <field name="step5_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 5}" class="btn-success"
                                        invisible="step5_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 5}"
                                        invisible="step5_state not in ('done_auto','done_manual')"/>
                            </group>
                            <group string="6. Contrato educativo final">
                                <field name="step6_state"/>
                                <field name="step6_cleared_by"/>
                                <field name="step6_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 6}" class="btn-success"
                                        invisible="step6_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 6}"
                                        invisible="step6_state not in ('done_auto','done_manual')"/>
                            </group>
                        </page>
                        <page string="Estudiantes">
                            <field name="student_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="grade"/>
                                    <field name="institutional_email"/>
                                    <field name="insurance_policy"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_enrollment_journey" model="ir.actions.act_window">
        <field name="name">Enrollment Journey</field>
        <field name="res_model">enrollment.journey</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_enrollment_journey_root" name="Inscripción 2026-2027"
              parent="sale.sale_menu_root" sequence="30"
              action="action_enrollment_journey"/>

</odoo>
