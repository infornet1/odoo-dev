<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_enrollment_journey_tree" model="ir.ui.view">
        <field name="name">enrollment.journey.tree</field>
        <field name="model">enrollment.journey</field>
        <field name="arch" type="xml">
            <tree decoration-warning="continuation_status == 'pending'"
                  decoration-success="continuation_status == 'confirmed'"
                  decoration-danger="continuation_status == 'declined'">
                <field name="partner_id"/>
                <field name="continuation_status" widget="badge"
                       decoration-warning="continuation_status == 'pending'"
                       decoration-success="continuation_status == 'confirmed'"
                       decoration-danger="continuation_status == 'declined'"/>
                <field name="blast_sent_date" optional="show" string="Email S0"/>
                <field name="email_missing" optional="show" string="Sin email"/>
                <field name="email_bounced" optional="show" string="Rebotado"/>
                <field name="wa_sent_date" optional="show" string="WA enviado"/>
                <field name="phone_missing" optional="show" string="Sin tel."/>
                <field name="order_id" optional="hide"/>
                <field name="quote_state" optional="show" widget="badge"
                       decoration-warning="quote_state == 'draft'"
                       decoration-info="quote_state == 'sent'"
                       decoration-success="quote_state == 'accepted'"
                       decoration-danger="quote_state == 'revision_requested'"/>
                <field name="progress_pct" widget="progressbar"/>
                <field name="current_step" optional="hide"/>
                <field name="step3_state" optional="hide"/>
                <field name="contract_retained" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_enrollment_journey_form" model="ir.ui.view">
        <field name="name">enrollment.journey.form</field>
        <field name="model">enrollment.journey</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="continuation_status" widget="statusbar"
                           statusbar_visible="pending,confirmed,declined"/>
                    <button name="action_send_blast_email" type="object"
                            string="📧 Enviar email S0" class="btn-primary"
                            invisible="blast_sent_date != False"
                            confirm="¿Enviar el email de invitación S0 al representante?"/>
                    <button name="action_send_blast_email" type="object"
                            string="📧 Reenviar email S0" class="btn-secondary"
                            invisible="blast_sent_date == False"/>
                    <button name="action_send_wa" type="object"
                            string="📱 Enviar WA" class="btn-secondary"/>
                    <button name="action_reset_confirmation" type="object"
                            string="🔄 Restablecer S0" class="btn-secondary"
                            invisible="continuation_status == 'pending'"
                            confirm="¿Restablecer la confirmación S0 a pendiente? El representante verá la pregunta nuevamente."/>
                    <button name="action_preview_import" type="object"
                            string="📥 Importar estudiantes" class="btn-secondary"
                            invisible="student_ids != []"/>
                    <button name="action_preview_import" type="object"
                            string="🔄 Re-sincronizar Akdemia" class="btn-secondary"
                            invisible="student_ids == []"/>
                    <button name="action_run_soft_checks" type="object"
                            string="🔄 Validaciones automáticas" class="btn-secondary"/>
                    <button name="action_open_journey_page" type="object"
                            string="🌐 Ver página del Representante" class="btn-secondary"/>
                    <button name="action_send_quote" type="object"
                            string="📤 Enviar cotización" class="btn-primary"
                            invisible="quote_state != 'draft'"
                            confirm="¿Enviar la cotización al representante para su revisión y aceptación? Se congelará la versión actual (PDF + hash) y se le enviará el enlace."/>
                    <button name="action_send_quote" type="object"
                            string="🔁 Re-emitir cotización" class="btn-primary"
                            invisible="quote_state not in ('sent','accepted','revision_requested')"
                            confirm="¿Re-emitir la cotización? Se congelará una nueva versión a partir de la orden actual, se reemplazará la anterior y se enviará al representante (mismo enlace y QR)."/>
                    <button name="action_print_contract" type="object"
                            string="🖨️ Imprimir Contrato" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="partner_id" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="order_id"/>
                            <field name="academic_year"/>
                            <field name="progress_pct" widget="progressbar"/>
                        </group>
                        <group>
                            <field name="contract_number" readonly="1"/>
                            <field name="contract_date"/>
                            <field name="journey_url" widget="url" readonly="1"/>
                            <field name="access_token" readonly="1" groups="base.group_system"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="S0 — Continuidad">
                            <group string="Respuesta del Representante">
                                <group>
                                    <field name="continuation_status"/>
                                    <field name="confirmation_date" readonly="1"/>
                                    <field name="decline_date" readonly="1"/>
                                </group>
                                <group>
                                    <field name="blast_sent_date" readonly="1"/>
                                    <field name="email_missing" readonly="1"/>
                                    <field name="email_bounced"/>
                                    <field name="wa_sent_date" readonly="1"/>
                                    <field name="phone_missing" readonly="1"/>
                                </group>
                            </group>
                            <group string="Motivo de No Continuidad"
                                   invisible="continuation_status != 'declined'">
                                <field name="decline_reason" readonly="1" nolabel="1"
                                       widget="text"/>
                            </group>
                        </page>
                        <page string="Pasos">

                            <!-- BLOQUE 1 — Inscripción Formal -->
                            <separator string="🏛️ Bloque 1 — Inscripción Formal"/>

                            <group string="1. Cotización confirmada">
                                <group>
                                    <field name="quote_state"/>
                                    <field name="quote_version"/>
                                    <field name="quote_sent_date" readonly="1"
                                           invisible="quote_state in ('none','draft')"/>
                                    <field name="quote_accepted_date" readonly="1"
                                           invisible="quote_state != 'accepted'"/>
                                </group>
                                <group>
                                    <field name="step1_state"/>
                                    <field name="step1_cleared_by"/>
                                    <field name="step1_cleared_at"/>
                                </group>
                                <field name="quote_revision_reason" readonly="1" colspan="2"
                                       invisible="quote_state != 'revision_requested'"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 1}" class="btn-success"
                                        invisible="step1_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 1}"
                                        invisible="step1_state not in ('done_auto','done_manual')"/>
                            </group>

                            <group string="2. Acuerdo de Inscripción firmado">
                                <field name="step2_state"/>
                                <field name="step2_cleared_by"/>
                                <field name="step2_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 2}" class="btn-success"
                                        invisible="step2_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 2}"
                                        invisible="step2_state not in ('done_auto','done_manual')"/>
                            </group>

                            <group string="3. Contrato Educativo firmado">
                                <field name="step3_state"/>
                                <field name="step3_cleared_by"/>
                                <field name="step3_cleared_at"/>
                                <field name="contract_retained" readonly="1"
                                       invisible="step3_state not in ('done_auto','done_manual')"/>
                                <field name="contract_released_date" readonly="1"
                                       invisible="contract_retained or step3_state not in ('done_auto','done_manual')"/>
                                <button name="action_clear_step" type="object"
                                        string="✅ Contrato firmado (en custodia)"
                                        context="{'step': 3}" class="btn-success"
                                        invisible="step3_state in ('done_auto','done_manual')"/>
                                <button name="action_release_contract" type="object"
                                        string="📋 Liberar contrato al Representante"
                                        class="btn-primary"
                                        invisible="not contract_retained or step3_state not in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 3}"
                                        invisible="step3_state not in ('done_auto','done_manual')"/>
                            </group>

                            <!-- BLOQUE 2 — Activación de Plataformas -->
                            <separator string="💻 Bloque 2 — Activación de Plataformas"/>

                            <group string="4. Registro Akdemia completo">
                                <field name="step4_state"/>
                                <field name="step4_cleared_by"/>
                                <field name="step4_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 4}" class="btn-success"
                                        invisible="step4_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 4}"
                                        invisible="step4_state not in ('done_auto','done_manual')"/>
                            </group>

                            <group string="5. Cuenta Dawere habilitada">
                                <field name="step5_state"/>
                                <field name="step5_cleared_by"/>
                                <field name="step5_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 5}" class="btn-success"
                                        invisible="step5_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 5}"
                                        invisible="step5_state not in ('done_auto','done_manual')"/>
                            </group>

                            <group string="6. Cuenta @ueipab.edu.ve actualizada">
                                <field name="step6_state"/>
                                <field name="step6_cleared_by"/>
                                <field name="step6_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 6}" class="btn-success"
                                        invisible="step6_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 6}"
                                        invisible="step6_state not in ('done_auto','done_manual')"/>
                            </group>

                            <group string="7. Google Classroom">
                                <field name="step7_state"/>
                                <field name="step7_cleared_by"/>
                                <field name="step7_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 7}" class="btn-success"
                                        invisible="step7_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 7}"
                                        invisible="step7_state not in ('done_auto','done_manual')"/>
                            </group>

                            <!-- BLOQUE 3 — Cierre Administrativo -->
                            <separator string="📁 Bloque 3 — Cierre Administrativo"/>

                            <group string="8. Guía de Inglés entregada">
                                <field name="step8_state"/>
                                <field name="step8_cleared_by"/>
                                <field name="step8_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 8}" class="btn-success"
                                        invisible="step8_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 8}"
                                        invisible="step8_state not in ('done_auto','done_manual')"/>
                            </group>

                            <group string="9. Expediente físico actualizado">
                                <field name="step9_state"/>
                                <field name="step9_cleared_by"/>
                                <field name="step9_cleared_at"/>
                                <button name="action_clear_step" type="object" string="✅ Completar"
                                        context="{'step': 9}" class="btn-success"
                                        invisible="step9_state in ('done_auto','done_manual')"/>
                                <button name="action_reopen_step" type="object" string="↩️ Reabrir"
                                        context="{'step': 9}"
                                        invisible="step9_state not in ('done_auto','done_manual')"/>
                            </group>

                        </page>
                        <page string="Estudiantes">
                            <field name="student_ids">
                                <tree editable="bottom" decoration-muted="source == 'akdemia' and not staff_edited">
                                    <field name="name"/>
                                    <field name="cedula"/>
                                    <field name="grade"/>
                                    <field name="institutional_email"/>
                                    <field name="insurance_policy"/>
                                    <field name="source" optional="show"/>
                                    <field name="staff_edited" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Cotización — Versiones">
                            <field name="quote_version_ids" readonly="1">
                                <tree decoration-success="state == 'accepted'"
                                      decoration-muted="state == 'superseded'"
                                      decoration-warning="state == 'issued'">
                                    <field name="version"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'accepted'"
                                           decoration-warning="state == 'issued'"
                                           decoration-muted="state == 'superseded'"
                                           decoration-danger="state == 'rejected'"/>
                                    <field name="amount_total"/>
                                    <field name="currency_id" optional="hide"/>
                                    <field name="issued_date"/>
                                    <field name="issued_by" optional="show"/>
                                    <field name="accept_ip" optional="show"/>
                                    <field name="accept_timestamp_utc" optional="show"/>
                                    <field name="tyc_accepted" optional="hide"/>
                                    <field name="pdf_sha256" optional="show"/>
                                    <field name="pdf_attachment_id" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_enrollment_journey" model="ir.actions.act_window">
        <field name="name">Inscripción 2026-2027</field>
        <field name="res_model">enrollment.journey</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Staff S0 review: pending or bounced, no response yet -->
    <record id="action_enrollment_s0_review" model="ir.actions.act_window">
        <field name="name">Revisión S0 — Pendientes y Rebotes</field>
        <field name="res_model">enrollment.journey</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('continuation_status', 'in', ['pending', 'declined']), '|', ('email_bounced', '=', True), ('blast_sent_date', '!=', False)]</field>
        <field name="context">{'search_default_group_by_status': 1}</field>
    </record>

    <menuitem id="menu_enrollment_journey_root" name="Inscripción 2026-2027"
              parent="sale.sale_menu_root" sequence="30"
              action="action_enrollment_journey"/>

    <menuitem id="menu_enrollment_s0_review" name="Revisión S0"
              parent="sale.sale_menu_root" sequence="31"
              action="action_enrollment_s0_review"/>

    <!-- Akdemia import diff preview wizard -->
    <record id="view_enrollment_student_import_preview_form" model="ir.ui.view">
        <field name="name">enrollment.student.import.preview.form</field>
        <field name="model">enrollment.student.import.preview</field>
        <field name="arch" type="xml">
            <form string="Vista previa — Importar estudiantes">
                <sheet>
                    <div class="oe_title">
                        <h2>Vista previa de sincronización con Akdemia</h2>
                    </div>
                    <group>
                        <field name="journey_id" readonly="1"/>
                    </group>
                    <field name="summary_html" readonly="1"/>
                    <field name="has_changes" invisible="1"/>
                    <field name="use_cache" invisible="1"/>
                    <p invisible="has_changes" class="text-muted">
                        No hay cambios que aplicar (todo está al día o solo hay conflictos
                        que requieren revisión manual).
                    </p>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="✅ Aplicar importación"
                            class="btn-primary" invisible="not has_changes"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
