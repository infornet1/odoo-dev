<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ai_agent_freescout_task_view_list" model="ir.ui.view">
        <field name="name">ai.agent.freescout.task.list</field>
        <field name="model">ai.agent.freescout.task</field>
        <field name="arch" type="xml">
            <tree string="Pagos Freescout"
                  decoration-success="status == 'success'"
                  decoration-warning="status in ('no_receipt', 'duplicate', 'identified')"
                  decoration-danger="status in ('no_partner', 'error')"
                  decoration-muted="status == 'pending'">
                <field name="fs_conv_id" string="Conv #"/>
                <field name="fs_subject" string="Asunto"/>
                <field name="sender_email" string="Remitente"/>
                <field name="partner_id" string="Cliente"/>
                <field name="sheet_match" string="Hoja Customers" optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-warning="status in ('no_receipt', 'duplicate', 'identified')"
                       decoration-danger="status in ('no_partner', 'error')"/>
                <field name="payment_odoo_id" string="Pago ID" optional="show"/>
                <field name="retry_count" string="Reintentos" optional="show"/>
                <field name="last_processed_at" string="Procesado"/>
            </tree>
        </field>
    </record>

    <record id="ai_agent_freescout_task_view_form" model="ir.ui.view">
        <field name="name">ai.agent.freescout.task.form</field>
        <field name="model">ai.agent.freescout.task</field>
        <field name="arch" type="xml">
            <form string="Tarea Freescout">
                <header>
                    <button name="action_reprocess"
                            string="Re-procesar"
                            type="object"
                            class="btn-primary"
                            confirm="Se publicará una nota en Freescout y se actualizará el estado. ¿Continuar?"/>
                    <button name="action_open_freescout"
                            string="Abrir en Freescout"
                            type="object"
                            class="btn-secondary"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,no_partner,identified,success"/>
                </header>
                <sheet>
                    <group string="Conversación Freescout">
                        <field name="fs_conv_id"/>
                        <field name="fs_subject"/>
                        <field name="sender_email"/>
                        <field name="last_processed_at"/>
                        <field name="retry_count"/>
                    </group>
                    <group string="Identificación">
                        <field name="partner_id"/>
                        <field name="sheet_match"/>
                        <field name="payment_odoo_id"/>
                    </group>
                    <group string="Datos extraídos">
                        <field name="extracted_json" nolabel="1" colspan="2" widget="text"
                               readonly="1"/>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1" colspan="2" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ai_agent_freescout_task_view_search" model="ir.ui.view">
        <field name="name">ai.agent.freescout.task.search</field>
        <field name="model">ai.agent.freescout.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="fs_subject"/>
                <field name="sender_email"/>
                <field name="partner_id"/>
                <filter name="no_partner" string="Sin cliente"
                        domain="[('status', '=', 'no_partner')]"/>
                <filter name="error" string="Con error"
                        domain="[('status', 'in', ['no_partner', 'error'])]"/>
                <filter name="success" string="Procesados"
                        domain="[('status', '=', 'success')]"/>
                <filter name="needs_review" string="Requieren revisión"
                        domain="[('status', 'in', ['no_partner', 'no_receipt', 'duplicate', 'error'])]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_status" string="Estado"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_partner" string="Cliente"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="ai_agent_freescout_task_action" model="ir.actions.act_window">
        <field name="name">Pagos Freescout</field>
        <field name="res_model">ai.agent.freescout.task</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_needs_review': 1}</field>
    </record>

</odoo>
