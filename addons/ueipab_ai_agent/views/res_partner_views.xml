<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_telegram" model="ir.ui.view">
        <field name="name">res.partner.form.telegram</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal']" position="after">
                <page name="canales_digitales" string="Canales Digitales">
                    <group string="Telegram">
                        <field name="telegram_chat_id" readonly="1"
                               placeholder="Pendiente — se llena al hacer clic en enlace de opt-in"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
