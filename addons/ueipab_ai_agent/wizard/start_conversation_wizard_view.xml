<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="start_conversation_wizard_view_form" model="ir.ui.view">
        <field name="name">ai.agent.start.conversation.wizard.form</field>
        <field name="model">ai.agent.start.conversation.wizard</field>
        <field name="arch" type="xml">
            <form string="Iniciar Conversacion WhatsApp">
                <group>
                    <field name="skill_id"/>
                    <field name="partner_id"/>
                    <field name="phone"/>
                </group>
                <group string="Mensaje del representante (opcional)">
                    <field name="initial_message" nolabel="1" colspan="2"
                           placeholder="Pega aquí el mensaje original del representante recibido por otro canal (correo, WA distinto, presencial). Glenda lo procesará automáticamente tras el saludo."
                           widget="text"/>
                </group>
                <group>
                    <field name="source_model" invisible="1"/>
                    <field name="source_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_start" string="Iniciar Conversacion"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <!-- Standalone action — opens wizard directly from AI Agent menu -->
    <record id="action_start_conversation_standalone" model="ir.actions.act_window">
        <field name="name">Iniciar Conversación WhatsApp</field>
        <field name="res_model">ai.agent.start.conversation.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="start_conversation_wizard_view_form"/>
        <field name="target">new</field>
    </record>

</odoo>
