<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Weekly document expiry check (RIF + Cedula) — every Monday at 08:00 VET (12:00 UTC) -->
        <record id="ir_cron_check_document_expiry" model="ir.cron">
            <field name="name">UEIPAB: Verificar vencimiento de documentos (RIF + Cedula)</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_document_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Daily reminder for pending info requests — 09:00 VET (13:00 UTC) -->
        <record id="ir_cron_employee_info_reminders" model="ir.cron">
            <field name="name">UEIPAB: Recordatorios de Solicitudes de Datos Personales</field>
            <field name="model_id" ref="ueipab_hr_employee.model_hr_employee_info_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
