<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Email template: Employee Private Info Request
        Model: hr.employee.info.request
        Render engine: qweb (default for mail.template)
        Note: URL is built via t-att-href string concatenation — safe pattern
              that survives ORM Html sanitizer without needing direct SQL.
    -->
    <record id="email_template_employee_info_request" model="mail.template">
        <field name="name">Solicitud de Datos Personales — Empleado</field>
        <field name="model_id" ref="ueipab_hr_employee.model_hr_employee_info_request"/>
        <field name="subject">Actualización de Datos Personales — UEIPAB</field>
        <field name="email_from">Recursos Humanos UEIPAB &lt;recursoshumanos@ueipab.edu.ve&gt;</field>
        <field name="email_to">{{object.employee_id.work_email}}</field>
        <field name="email_cc">recursoshumanos@ueipab.edu.ve</field>
        <field name="auto_delete">True</field>
        <field name="body_html" type="html">
<div style="font-family:Arial,Helvetica,sans-serif;max-width:640px;margin:0 auto;background:#f0f4fa;padding:20px 12px;">
<div style="background:#ffffff;border-radius:14px;box-shadow:0 4px 24px rgba(26,44,91,0.12);overflow:hidden;">

  <!-- Header -->
  <div style="background:linear-gradient(135deg,#1a2c5b 0%,#2471a3 100%);color:#ffffff;padding:28px 30px;text-align:center;">
    <p style="margin:0 0 6px;font-size:11px;letter-spacing:2px;text-transform:uppercase;opacity:0.75;">
      Instituto Privado Andrés Bello, CA — UEIPAB
    </p>
    <h1 style="margin:0 0 8px;font-size:21px;font-weight:bold;">
      Actualización de Datos Personales
    </h1>
    <p style="margin:0 0 12px;font-size:13px;opacity:0.85;">
      Recursos Humanos solicita tu colaboración
    </p>
    <span style="display:inline-block;background:rgba(255,255,255,0.18);
                 border:1px solid rgba(255,255,255,0.45);border-radius:20px;
                 padding:4px 16px;font-size:11px;font-weight:bold;
                 letter-spacing:1px;text-transform:uppercase;">
      📋 Fase 1 — Actualización de Datos Personales
    </span>
  </div>

  <!-- Body -->
  <div style="padding:28px 30px;">

    <p style="font-size:15px;color:#222;margin:0 0 18px;line-height:1.6;">
      Hola, <strong><t t-out="object.employee_id.name"/></strong>.
    </p>
    <!-- Phase banner -->
    <div style="background:#fff8e1;border:1px solid #ffe082;border-left:5px solid #f39c12;
                border-radius:8px;padding:12px 16px;margin-bottom:22px;
                display:flex;align-items:center;gap:10px;">
      <span style="font-size:20px;">📋</span>
      <div>
        <p style="margin:0 0 2px;font-size:12px;font-weight:bold;color:#b7770d;
                  text-transform:uppercase;letter-spacing:0.8px;">
          Fase 1 de actualización de datos
        </p>
        <p style="margin:0;font-size:13px;color:#7d5a00;line-height:1.5;">
          Esta es la primera fase del proceso de actualización de datos personales.
          Próximamente recibirás comunicaciones adicionales para completar tu expediente.
        </p>
      </div>
    </div>

    <p style="font-size:14px;color:#444;margin:0 0 24px;line-height:1.7;">
      El Departamento de Recursos Humanos te invita a revisar y confirmar
      tu información personal registrada en el sistema.
      Esto nos permite mantener tus datos actualizados y comunicarnos contigo
      de manera efectiva.
    </p>

    <!-- Section title -->
    <p style="font-size:11px;font-weight:bold;letter-spacing:1px;text-transform:uppercase;
              color:#2471a3;border-bottom:2px solid #e0eaf8;padding-bottom:8px;margin:0 0 12px;">
      Información registrada actualmente
    </p>

    <!-- Values table -->
    <table cellpadding="0" cellspacing="0" width="100%"
           style="border-collapse:collapse;font-size:13px;margin-bottom:26px;">

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;width:44%;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Cédula</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.identification_id">
            <t t-out="object.employee_id.identification_id"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Correo personal</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.private_email">
            <t t-out="object.employee_id.private_email"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Teléfono personal</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.private_phone">
            <t t-out="object.employee_id.private_phone"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Género</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.gender == 'male'">Masculino</t>
          <t t-elif="object.employee_id.gender == 'female'">Femenino</t>
          <t t-elif="object.employee_id.gender == 'other'">Otro</t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Fecha de nacimiento</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.birthday">
            <t t-out="object.employee_id.birthday"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Estado civil</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.marital == 'single'">Soltero/a</t>
          <t t-elif="object.employee_id.marital == 'married'">Casado/a</t>
          <t t-elif="object.employee_id.marital == 'cohabitant'">Unión concubinaria</t>
          <t t-elif="object.employee_id.marital == 'widower'">Viudo/a</t>
          <t t-elif="object.employee_id.marital == 'divorced'">Divorciado/a</t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Lugar de nacimiento</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.place_of_birth">
            <t t-out="object.employee_id.place_of_birth"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">País de nacimiento</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.country_of_birth">
            <t t-out="object.employee_id.country_of_birth.name"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Ciudad</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.private_city">
            <t t-out="object.employee_id.private_city"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Estado/Provincia</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.private_state_id">
            <t t-out="object.employee_id.private_state_id.name"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Código postal</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.private_zip">
            <t t-out="object.employee_id.private_zip"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">País de residencia</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.private_country_id">
            <t t-out="object.employee_id.private_country_id.name"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr style="border-bottom:1px solid #eef2f8;">
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Contacto de emergencia</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.emergency_contact">
            <t t-out="object.employee_id.emergency_contact"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

      <tr>
        <td style="padding:9px 12px;font-weight:bold;color:#1a2c5b;
                   background:#f8faff;font-size:12px;text-transform:uppercase;">Teléfono de emergencia</td>
        <td style="padding:9px 12px;color:#333;">
          <t t-if="object.employee_id.emergency_phone">
            <t t-out="object.employee_id.emergency_phone"/>
          </t>
          <t t-else=""><em style="color:#aaa;">No registrado</em></t>
        </td>
      </tr>

    </table>

    <!-- CTA button -->
    <div style="text-align:center;margin:26px 0;">
      <a t-att-href="object._get_form_url()"
         style="display:inline-block;background:#1a2c5b;color:#ffffff;
                text-decoration:none;padding:15px 38px;border-radius:10px;
                font-size:15px;font-weight:bold;letter-spacing:0.3px;">
        Confirmar / Actualizar mis datos
      </a>
    </div>

    <!-- Note -->
    <div style="background:#f0f4fa;border-radius:8px;padding:14px 16px;
                font-size:13px;color:#555;line-height:1.7;">
      Haz clic en el botón para revisar tu información y confirmar o actualizar
      los campos que necesiten corrección. El proceso toma menos de 2 minutos.
    </div>

  </div>

  <!-- Footer -->
  <div style="background:#f8f9fa;padding:14px 28px;text-align:center;
              border-top:1px solid #eaeaea;">
    <p style="margin:0;font-size:12px;color:#aaa;line-height:1.8;">
      Este enlace es personal e intransferible.<br/>
      Si tienes alguna dificultad comunícate con
      <a href="mailto:recursoshumanos@ueipab.edu.ve"
         style="color:#aaa;">recursoshumanos@ueipab.edu.ve</a>
    </p>
  </div>

</div>
</div>
        </field>
    </record>

</odoo>
